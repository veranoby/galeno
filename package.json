{
  "name": "galeno-monorepo",
  "version": "1.0.0",
  "description": "Galeno - Plataforma médica SaaS para Ecuador",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev:web",
    "dev:api": "turbo run dev:api",
    "build": "turbo run build",
    "build:web": "turbo run build:web",
    "build:api": "turbo run build:api",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky",
    "postinstall": "echo 'Skipping package build during install'",
    "ci:check": "turbo run lint --filter={apps/*} && turbo run type-check --filter={apps/*}",
    "ci:test": "turbo run test --filter={apps/*}",
    "ci:build": "turbo run build --filter={apps/*}",
    "ci:all": "turbo run lint --filter={apps/*} && turbo run type-check --filter={apps/*} && turbo run test --filter={apps/*} && turbo run build --filter={apps/*}"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@turbo/gen": "^2.4.2",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.0.0",
    "turbo": "^2.4.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1"
  }
}
