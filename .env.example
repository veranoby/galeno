# ============= DATABASE =============
# PostgreSQL local (sin Docker)
DATABASE_URL="postgresql://galeno:galeno_password@localhost:5432/galeno_db?schema=public"

# ============= API =============
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============= LOGGING =============
LOG_LEVEL=info

# ============= JWT =============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============= ENCRYPTION (AES-256-GCM) =============
# Clave de 32 bytes para cifrado de datos sensibles (LOPDP compliance)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your-32-byte-base64-key-for-aes-256-gcm-encryption

# ============= QR CODES =============
# Secret key for QR code signature generation (required for health wallet QR codes)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_SECRET=your-qr-secret-key-for-hmac-signature-generation

# ============= REDIS =============
REDIS_URL=redis://localhost:6379

# ============= IA SERVICES =============
GEMINI_API_KEY=your-gemini-api-key

# ============= SRI =============
SRI_AMBIENTE=pruebas
SRI_URL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantes?wsdl

# ============= WHATSAPP (Twilio) =============
# Twilio Account SID - https://www.twilio.com/docs/whatsapp
# Generar en: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WhatsApp Business API (Meta) - Opcional, alternativa a Twilio
# META_WHATSAPP_PHONE_ID=your-phone-id
# META_WHATSAPP_TOKEN=your-access-token
# META_WHATSAPP_BUSINESS_ID=your-business-id

# ============= EMAIL (Resend) =============
# RESEND_API_KEY=your-resend-api-key

# ============= PAYPHONE (Ecuador) =============
# PayPhone ID de comercio - Sandbox
PAYPHONE_ID=123456789
# PayPhone Secret Key - Sandbox (obtener de https://payphone.ec/)
PAYPHONE_SECRET=secret_sandbox_key
# PayPhone API URL - Sandbox
PAYPHONE_API_URL=https://api.payphone.ec/api/v1

# ============= PAYPAL (Internacional) =============
# PayPal Client ID - Sandbox (obtener de https://developer.paypal.com/)
PAYPAL_CLIENT_ID=sb-client-id
# PayPal Secret - Sandbox
PAYPAL_SECRET=sb-secret
# PayPal API URL - Sandbox
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# ============= GEO IP =============
# API Key para geolocalización por IP (ipapi.co o similar)
GEO_API_KEY=mock_geo_key
