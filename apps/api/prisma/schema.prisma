// ============= MODELOS PARA PAGOS (TASK-018) =============

model Pago {
  id            String        @id @default(uuid())
  cuentaId      String        @map("cuenta_id")
  gateway       String // 'payphone' | 'kushki' | 'stripe' | 'paymentez'
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  transactionId String        @unique @map("transaction_id")
  externalId    String?       @unique @map("external_id") // Idempotency key
  description   String?
  metadata      Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  approvedAt    DateTime?     @map("approved_at")

  // Relations
  splits PaymentSplit[]
  cuenta Cuenta         @relation(fields: [cuentaId], references: [id], onDelete: Cascade)

  @@index([cuentaId])
  @@index([gateway])
  @@index([status])
  @@index([transactionId])
  @@index([createdAt])
  @@map("pagos")
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
}

model PaymentSplit {
  id          String      @id @default(uuid())
  pagoId      String      @map("pago_id")
  recipientId String      @map("recipient_id") // cuenta_id del recipiente
  amount      Decimal     @db.Decimal(10, 2)
  percentage  Float
  status      SplitStatus @default(PENDING)
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  paidAt      DateTime?   @map("paid_at")

  // Relations
  pago      Pago   @relation(fields: [pagoId], references: [id], onDelete: Cascade)
  recipient Cuenta @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([pagoId])
  @@index([recipientId])
  @@index([status])
  @@map("payment_splits")
}

enum SplitStatus {
  PENDING
  PAID
  FAILED
}

model PaymentWebhookLog {
  id            String    @id @default(uuid())
  gateway       String // 'payphone' | 'kushki'
  event         String // Tipo de evento
  transactionId String?   @map("transaction_id")
  payload       Json
  signature     String?
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at")
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([gateway])
  @@index([event])
  @@index([transactionId])
  @@index([createdAt])
  @@map("payment_webhook_logs")
}

// ============= MODELOS PARA MÓDULOS DINÁMICOS (TASK-44B) =============

model ModuleData {
  id         String   @id @default(uuid())
  moduleId   String   @map("module_id")
  pacienteId String   @map("paciente_id")
  consultaId String?  @map("consulta_id")
  datos      Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relaciones
  paciente Paciente  @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  consulta Consulta? @relation(fields: [consultaId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([pacienteId])
  @@index([consultaId])
  @@map("module_data")
}

// ============= MARKETPLACE DE MÓDULOS (TASK-016) =============

model ModuleActivation {
  id         String   @id @default(uuid())
  cuentaId   String   @map("cuenta_id")
  moduleId   String   @map("module_id")
  activo     Boolean  @default(false)
  fechaActivacion DateTime? @map("fecha_activacion")
  fechaDesactivacion DateTime? @map("fecha_desactivacion")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relaciones
  cuenta     Cuenta   @relation(fields: [cuentaId], references: [id], onDelete: Cascade)

  @@unique([cuentaId, moduleId])
  @@index([cuentaId])
  @@index([moduleId])
  @@index([activo])
  @@map("module_activations")
}

// ============= CACHE SENESCYT (BIZ-001) =============

model SenescytCache {
  id            String   @id @default(uuid())
  cedula        String   @map("cedula")
  numeroTitulo  String   @map("numero_titulo")
  result        Json
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([cedula, numeroTitulo], map: "senescyt_cache_cedula_numeroTitulo")
  @@index([expiresAt])
  @@map("senescyt_cache")
}

// ============= TELEMETRÍA DE TELECONSULTAS (FASE 3) =============

model MetricLog {
  id        String   @id @default(uuid())
  sessionId String   @unique @map("session_id")
  consultaId String? @map("consulta_id")
  userId    String   @map("user_id")
  
  // Métricas de calidad de red
  jitter    Decimal  @default(0) @db.Decimal(10, 3)
  latency   Decimal  @default(0) @db.Decimal(10, 3)
  packetLoss Decimal  @default(0) @db.Decimal(5, 4)
  
  // Métricas de calidad de video/audio
  videoQuality String? @map("video_quality") // 'high', 'medium', 'low'
  audioQuality String? @map("audio_quality")
  
  // Duración en segundos
  duration  Int      @default(0)
  
  // Metadata adicional
  metadata  Json?
  
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([consultaId])
  @@index([userId])
  @@index([createdAt])
  @@map("metric_logs")
}
