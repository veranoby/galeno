# ============= DATABASE =============
# PostgreSQL local (sin Docker)
DATABASE_URL="postgresql://galeno:galeno_password@localhost:5432/galeno_db?schema=public"

# ============= API =============
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============= LOGGING =============
LOG_LEVEL=info

# ============= JWT =============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============= REDIS =============
REDIS_URL=redis://localhost:6379

# ============= IA SERVICES =============
GEMINI_API_KEY=your-gemini-api-key

# ============= SRI =============
SRI_AMBIENTE=pruebas
SRI_URL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantes?wsdl
