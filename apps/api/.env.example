# ============= DATABASE =============
# PostgreSQL local (sin Docker)
DATABASE_URL="postgresql://galeno:galeno_password@localhost:5432/galeno_db?schema=public"

# ============= API =============
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============= LOGGING =============
LOG_LEVEL=info

# ============= JWT =============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ============= ENCRYPTION (AES-256-GCM) =============
# Clave de 32 bytes para cifrado de datos sensibles (LOPDP compliance)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your-32-byte-base64-key-for-aes-256-gcm-encryption

# ============= QR CODES =============
# Secret key for QR code signature generation (required for health wallet QR codes)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_SECRET=your-qr-secret-key-for-hmac-signature-generation

# ============= REDIS =============
REDIS_URL=redis://localhost:6379

# ============= IA SERVICES =============
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PROJECT_ID=gen-lang-client-0927044113
GEMINI_MODEL=gemini-1.5-flash

# ============= SRI =============
SRI_AMBIENTE=pruebas
SRI_URL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantes?wsdl

# ============= STORAGE =============
# Ruta local para almacenamiento de archivos (desarrollo)
STORAGE_PATH=./storage
# Tamaño máximo de archivo en bytes (10MB por defecto)
STORAGE_MAX_FILE_SIZE=10485760

# ============= JITSI MEET =============
# Configuración para videoconferencias con Jitsi Meet
# Dominio del servidor Jitsi (meet.jit.si para público, o tu propio dominio)
JITSI_DOMAIN=meet.jit.si
# App ID y Secret para generar JWT tokens (requerido para dominio propio)
# Obtén estos valores en: https://jaas.8x8.vc/
JITSI_APP_ID=
JITSI_APP_SECRET=
# Salt para generar nombres de sala seguros (cámbialo en producción)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JITSI_SALT=change-this-to-a-random-salt-in-production

# ============= EMAIL SERVICE (RESEND) =============
# API key para envío de emails transaccionales
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Email remitente (debe estar verificado en Resend)
RESEND_FROM=noreply@galeno.ec
# URL del frontend para links en emails
FRONTEND_URL=https://galeno.ec

# ============= PAYMENT GATEWAYS (TASK-018) =============
# Payphone (Ecuador) - https://payphone.com.ec/developers
PAYPHONE_API_KEY=your_payphone_api_key
PAYPHONE_SECRET_KEY=your_payphone_secret_key
PAYPHONE_WEBHOOK_SECRET=your_payphone_webhook_secret

# Kushki (Ecuador/Perú) - https://docs.kushkipagos.com/
KUSHKI_PUBLIC_MERCHANT_ID=your_kushki_public_merchant_id
KUSHKI_PRIVATE_MERCHANT_ID=your_kushki_private_merchant_id
KUSHKI_WEBHOOK_SECRET=your_kushki_webhook_secret

# Paymentez (Ecuador) - https://docs.paymentez.com/
PAYMENTEZ_CLIENT_TOKEN=your_paymentez_client_token
PAYMENTEZ_APP_CODE=your_paymentez_app_code
PAYMENTEZ_API_URL=https://api.paymentez.com/v2

# Stripe (Internacional) - https://stripe.com/developers
# Opcional: Para suscripciones internacionales
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Split de comisiones (porcentajes)
GALENO_COMMISSION_PERCENTAGE=15
DOCTOR_COMMISSION_PERCENTAGE=85
