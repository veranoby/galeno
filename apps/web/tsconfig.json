{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuild.txt",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@galeno/shared-types": ["../../packages/shared-types/src"],
      "@galeno/ui-components": ["../../packages/ui-components/src"],
      "@galeno/api-client": ["../../packages/api-client/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "references": [
    { "path": "../shared-types" },
    { "path": "../ui-components" },
    { "path": "../api-client" }
  ]
}
