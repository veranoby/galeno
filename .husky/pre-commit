#!/usr/bin/env sh

echo "🚀 Running pre-commit checks..."

# Check if we have staged files to check
if [ -z "$(git diff --cached --name-only)" ]; then
  echo "No staged files to check."
  exit 0
fi

# Lint check (using lint-staged)
echo "📝 Running lint on staged files..."
npx lint-staged
LINT_STATUS=$?

if [ $LINT_STATUS -ne 0 ]; then
  echo "❌ Lint failed. Please fix the linting errors before committing."
  echo "Run 'pnpm lint:fix' to auto-fix linting issues."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
