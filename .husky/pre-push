#!/usr/bin/env sh

echo "🚀 Running pre-push checks..."

# Build entire project with Turbo (uses cache)
echo "🏗️ Running build pipeline with Turbo..."
pnpm build
BUILD_STATUS=$?

# Exit with code 1 if build failed
if [ $BUILD_STATUS -ne 0 ]; then
  echo "❌ Build failed. Please fix build errors before pushing."
  echo "Run 'pnpm build' to see build errors."
  exit 1
fi

echo "✅ Pre-push checks passed!"
